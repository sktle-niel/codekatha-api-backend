# Copy this file to ".env" and fill in real values.
# .env stays at the project root — OUTSIDE the public/ web root — so it is
# never served over HTTP. Never commit the real .env.

# --- Database ---
# On Hostinger the host is usually "localhost". The DB name + user are the
# prefixed ones shown in hPanel > Databases (e.g. u123456_codekathax).
DB_HOST=localhost
DB_PORT=3306
DB_NAME=codekathax
DB_USER=root
DB_PASS=

# --- CORS ---
# Comma-separated list of frontend origins allowed to call this API.
# Add your real site here once deployed. Use "*" for quick testing only.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# --- Anti-spam ---
# Secret salt used to hash visitor IPs for rate limiting. Set a long random
# value in production (any random string works; keep it private).
IP_SALT=change-this-to-a-long-random-string

# --- Email (where new requests are sent) ---
MAIL_TO=niel.ladica07@gmail.com
MAIL_FROM=no-reply@codekathax.com
MAIL_FROM_NAME=CODEKATHAX Website
MAIL_ENABLED=true

# --- SMTP (how the email is sent) ---
# OPTION A — Gmail: create an App Password (Google Account > Security >
#   2-Step Verification > App passwords) and use it as SMTP_PASS.
#     SMTP_HOST=smtp.gmail.com
#     SMTP_PORT=465
#     SMTP_SECURE=ssl
#     SMTP_USER=your.gmail@gmail.com
#     SMTP_PASS=your-16-char-app-password
#
# OPTION B — Hostinger mailbox (create one in hPanel > Emails):
#     SMTP_HOST=smtp.hostinger.com
#     SMTP_PORT=465
#     SMTP_SECURE=ssl
#     SMTP_USER=no-reply@codekathax.com
#     SMTP_PASS=your-mailbox-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USER=
SMTP_PASS=
