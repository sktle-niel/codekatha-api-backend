# Web root for the API subdomain (e.g. api.codekathax.com).

# No directory listings.
Options -Indexes

# Pass the Authorization header (Bearer tokens) through to PHP.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP:Authorization} .
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>

# Block access to any dotfiles (.env, .htaccess) that might end up here.
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
